# Copy this file to .env (in the project root, next to pyproject.toml) and
# fill in real values. .env is (and must stay) gitignored - never commit a
# real DEEPSEEK_AUTH_TOKEN. The old docker-compose.yml had a real token
# hardcoded in plaintext as a fallback default; this project intentionally
# does not ship one anywhere.

# Bearer token for chat.deepseek.com. Obtain it by logging in via
# `python -m deepseek4free.cloudflare.cookie_refresher --manual` and
# reading the userToken it saves to data/cookies.json, or by extracting it
# from your browser's DevTools -> Application -> Local Storage while logged
# in to chat.deepseek.com.
DEEPSEEK_AUTH_TOKEN=

# Where cookies.json is read from / written to. Relative paths resolve
# against the current working directory the process is started from.
DEEPSEEK_DATA_DIR=data

# Cloudflare-bypass service (cloudflare/bypass_server.py).
DOCKERMODE=false
SERVER_PORT=8000
SERVER_READY_TIMEOUT=30

# Chat HTTP server (server/app.py).
FASTAPI_SERVER_PORT=8018
MAX_UPLOAD_BYTES=52428800

# Ollama-compatible HTTP server (server/ollama_compat/app.py), run as a
# separate process on its own port so Ollama-speaking clients (Continue.dev,
# Open WebUI, langchain's ChatOllama, etc.) can point apiBase at it directly.
# Port 11434 matches real Ollama's default on purpose.
OLLAMA_COMPAT_PORT=11434
ENABLE_OLLAMA_API=true

LOG_LEVEL=INFO
